# Dual Backend Strategy Configuration
USE_PYTHON_BACKEND=true
VITE_BACKEND_URL=http://localhost:8000

# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Database Configuration (for future persistence)
DATABASE_URL=postgresql://user:password@localhost:5432/communityos

# Security
JWT_SECRET=your_jwt_secret_here

# Google Cloud Platform Configuration
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account.json

# Optional GCP integrations settings
FIRESTORE_DATABASE=(default)
GCS_BUCKET_NAME=your_gcp_project_id-communityos-rag-docs
PUBSUB_TOPIC=communityos-alerts
BIGQUERY_DATASET=communityos_telemetry
BIGQUERY_TABLE=history
